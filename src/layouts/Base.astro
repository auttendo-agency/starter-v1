---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { m } from '../paraglide/messages.js';
import { getLocale, getTextDirection, baseLocale } from '../paraglide/runtime.js';

interface Props {
  title?: string;
  description?: string;
  transparentNav?: boolean;
  redirectLocale?: boolean;
}

const {
  title = m.site_title(),
  description = m.site_description(),
  transparentNav = false,
  redirectLocale = false,
} = Astro.props;

const lang = getLocale();
const dir = getTextDirection();
// First-visit locale redirect. Inert on single-locale builds (nothing passes
// redirectLocale). On a multilingual site, set redirectLocale on the base-locale
// homepage so non-base-language visitors are bounced to /en/ once. Pure SSG, no
// adapter needed (the redirect runs client-side, not in middleware).
const enableLocaleRedirect = redirectLocale && lang === baseLocale;
---
<!doctype html>
<html lang={lang} dir={dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Manrope:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    {enableLocaleRedirect && (
      <script is:inline>
        (function () {
          try {
            if (window.location.pathname !== '/') return;
            var KEY = 'locale-redirect';
            if (localStorage.getItem(KEY)) return;
            localStorage.setItem(KEY, '1');
            var lang = (navigator.language || '').toLowerCase();
            // Visitor's browser matches the base locale: keep them at the root.
            if (lang.indexOf('nl') === 0) return;
            // Anything else: send to the English variant.
            window.location.replace('/en/');
          } catch (e) {
            /* no-op */
          }
        })();
      </script>
    )}
  </head>
  <body>
    <Nav transparent={transparentNav} />
    <main>
      <slot />
    </main>
    <Footer />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            }
          });
        },
        { rootMargin: '0px 0px -10% 0px', threshold: 0.05 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>

    <!-- Auttendo badge. Replace data-site with this site's slug before launch. -->
    <script
      src="https://cdn.auttendo.com/v1.js"
      data-site="REPLACE_ME"
      defer></script>
  </body>
</html>
