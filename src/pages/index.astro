---
import Base from '../layouts/Base.astro';
---
<Base transparentNav>
  <section class="relative min-h-[80vh] flex items-end bg-ink text-white overflow-hidden">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-10 py-24 w-full">
      <p class="eyebrow !text-white/70 reveal">
        <span class="inline-block w-7 h-px bg-current align-middle mr-3 opacity-60"></span>
        Eyebrow
      </p>
      <h1 class="headline text-5xl md:text-7xl lg:text-8xl mt-6 max-w-4xl reveal" style="transition-delay: 100ms">
        Headline goes here.
      </h1>
      <p class="mt-8 max-w-xl text-white/70 text-lg leading-relaxed reveal" style="transition-delay: 200ms">
        Supporting paragraph. Replace this hero per project.
      </p>
    </div>
  </section>

  <section class="max-w-[1400px] mx-auto px-6 lg:px-10 py-32">
    <p class="text-muted text-lg max-w-2xl reveal">
      Replace this content with the rebuilt site's homepage sections.
    </p>
  </section>
</Base>
